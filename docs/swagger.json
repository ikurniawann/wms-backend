{
  "swagger": "2.0",
  "info": {
    "description": "Warehouse Management System API documentation",
    "title": "WMS API",
    "version": "1.0.0"
  },
  "host": "localhost:8080",
  "basePath": "/",
  "schemes": ["http", "https"],
  "securityDefinitions": {
    "BearerAuth": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header",
      "description": "Enter your Bearer token in the format: Bearer {token}"
    }
  },
  "paths": {
    "/health": {
      "get": {
        "tags": ["health"],
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "type": "object",
              "properties": {
                "status": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "/api/v1/products": {
      "get": {
        "security": [{"BearerAuth": []}],
        "tags": ["products"],
        "summary": "List products",
        "parameters": [
          {"name": "page", "in": "query", "type": "integer", "default": 1},
          {"name": "page_size", "in": "query", "type": "integer", "default": 20},
          {"name": "q", "in": "query", "type": "string"}
        ],
        "responses": {
          "200": {"description": "OK"}
        }
      },
      "post": {
        "security": [{"BearerAuth": []}],
        "tags": ["products"],
        "summary": "Create product",
        "responses": {
          "201": {"description": "Created"}
        }
      }
    },
    "/api/v1/inventory/stocks": {
      "get": {
        "security": [{"BearerAuth": []}],
        "tags": ["inventory"],
        "summary": "List stocks",
        "responses": {
          "200": {"description": "OK"}
        }
      }
    },
    "/api/v1/customers": {
      "get": {
        "security": [{"BearerAuth": []}],
        "tags": ["customers"],
        "summary": "List customers",
        "responses": {
          "200": {"description": "OK"}
        }
      }
    },
    "/api/v1/suppliers": {
      "get": {
        "security": [{"BearerAuth": []}],
        "tags": ["suppliers"],
        "summary": "List suppliers",
        "responses": {
          "200": {"description": "OK"}
        }
      }
    },
    "/api/v1/sales/orders": {
      "get": {
        "security": [{"BearerAuth": []}],
        "tags": ["sales"],
        "summary": "List sales orders",
        "responses": {
          "200": {"description": "OK"}
        }
      },
      "post": {
        "security": [{"BearerAuth": []}],
        "tags": ["sales"],
        "summary": "Create sales order",
        "responses": {
          "201": {"description": "Created"}
        }
      }
    },
    "/api/v1/purchase/orders": {
      "get": {
        "security": [{"BearerAuth": []}],
        "tags": ["purchase"],
        "summary": "List purchase orders",
        "responses": {
          "200": {"description": "OK"}
        }
      },
      "post": {
        "security": [{"BearerAuth": []}],
        "tags": ["purchase"],
        "summary": "Create purchase order",
        "responses": {
          "201": {"description": "Created"}
        }
      }
    }
  }
}
